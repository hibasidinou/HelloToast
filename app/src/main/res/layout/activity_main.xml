<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Gradient background -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="20dp"
        android:background="#D4C4B9">


        <!-- Counter -->
        <TextView
            android:id="@+id/compteurText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0"
            android:textAlignment="center"
            android:textSize="100sp"
            android:textStyle="bold"
            android:textColor="#371B92"
            android:layout_marginBottom="80dp"
            android:elevation="4dp"/>

        <!-- Toast button -->
        <Button
            android:id="@+id/btnToast"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="* HELLO TOAST *"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:backgroundTint="#26A71A"
            android:layout_marginBottom="15dp"
            android:elevation="8dp"/>

        <!-- Counter button -->
        <Button
            android:id="@+id/btnCompteur"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="INCREASE"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:backgroundTint="#77C2"
            android:elevation="8dp"/>

    </LinearLayout>

</LinearLayout>



<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="30dp"
    android:background="#F5F5F7"> <TextView
        android:id="@+id/compteurText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0"
        android:textSize="120sp"
        android:textColor="#2D3436"
        android:textStyle="bold"
        android:layout_marginBottom="50dp" />

    <Button
        android:id="@+id/btnToast"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:text="SAY HELLO"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#6C5CE7"
        android:layout_marginBottom="15dp"
        app:cornerRadius="15dp" /> <Button
        android:id="@+id/btnCompteur"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:text="COUNT"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#00B894"
        app:cornerRadius="15dp" />

</LinearLayout>